FROM node:22 AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN NODE_OPTIONS=--max-old-space-size=4096 node_modules/.bin/tsc -p apps/gateway/tsconfig.app.json || true
RUN find /app/dist -name "main.js" 2>/dev/null || echo "NO main.js found"

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY proto ./proto

EXPOSE 3000
CMD ["node", "dist/apps/gateway/main.js"]
