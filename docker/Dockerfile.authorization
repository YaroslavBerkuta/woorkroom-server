FROM node:22 AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN NODE_OPTIONS=--max-old-space-size=4096 npm run build -- authorization && test -f dist/apps/authorization/main.js

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY proto ./proto

EXPOSE 5002 6003
CMD ["node", "dist/apps/authorization/main.js"]
