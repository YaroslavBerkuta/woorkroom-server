FROM node:22 AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN node_modules/.bin/nest --version \
    && NODE_OPTIONS=--max-old-space-size=4096 node_modules/.bin/nest build users \
    && test -f dist/apps/users/main.js

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY proto ./proto

EXPOSE 5001 6001
CMD ["node", "dist/apps/users/main.js"]
